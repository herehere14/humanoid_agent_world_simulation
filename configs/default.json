{
  "router": {
    "top_k": 3,
    "exploration": 0.2,
    "min_candidates": 2
  },
  "optimizer": {
    "learning_rate": 0.08,
    "weight_decay": 0.03,
    "min_weight": 0.1,
    "max_weight": 3.0,
    "prompt_rewrite_threshold": 0.46,
    "max_prompt_variants": 5,
    "candidate_trial_episodes": 6,
    "candidate_promote_threshold": 0.62,
    "candidate_failure_trigger": 4
  },
  "memory": {
    "max_records": 5000,
    "similarity_window": 120
  },
  "evaluator": {
    "aggregation_strategy": "judge_select",
    "reward_mode": "hybrid"
  },
  "artifacts_dir": "artifacts"
}
