{
  "agent_runtimes": {
    "evaluator": {
      "enabled": true,
      "provider": "openai_compatible",
      "model": "gpt-4.1-mini",
      "api_key_env": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "temperature": 0.1,
      "max_output_tokens": 600,
      "timeout_seconds": 15
    },
    "optimizer": {
      "enabled": false,
      "provider": "openai_compatible",
      "model": "gpt-4.1-mini",
      "api_key_env": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "temperature": 0.1,
      "max_output_tokens": 700,
      "timeout_seconds": 15
    }
  }
}